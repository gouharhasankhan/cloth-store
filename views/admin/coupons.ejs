<%- include('./sidebar') %>
<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0"><i class="fas fa-ticket-alt me-2"></i>Manage Coupons</h3>
    <button class="btn btn-warning fw-bold" data-bs-toggle="modal" data-bs-target="#addCouponModal">
      <i class="fas fa-plus me-2"></i>New Coupon
    </button>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-dark">
            <tr>
              <th>Code</th><th>Type</th><th>Value</th><th>Min Order</th>
              <th>Uses</th><th>Expiry</th><th>Status</th><th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if(coupons.length === 0) { %>
              <tr><td colspan="8" class="text-center py-4 text-muted">Koi coupon nahi hai</td></tr>
            <% } %>
            <% coupons.forEach(c => { %>
              <tr>
                <td><span class="badge bg-dark fs-6"><%= c.code %></span></td>
                <td><span class="badge bg-secondary"><%= c.type === 'percent' ? 'Percent %' : 'Fixed ₹' %></span></td>
                <td class="fw-bold"><%= c.type === 'percent' ? c.value + '%' : '₹' + c.value %></td>
                <td>₹<%= c.min_order %></td>
                <td><%= c.used_count %><%= c.max_uses ? '/' + c.max_uses : '' %></td>
                <td><%= c.expires_at ? new Date(c.expires_at).toLocaleDateString('en-IN') : '—' %></td>
                <td>
                  <span class="badge <%= c.is_active ? 'bg-success' : 'bg-danger' %>">
                    <%= c.is_active ? 'Active' : 'Inactive' %>
                  </span>
                </td>
                <td>
                  <form action="/admin/coupons/toggle/<%= c.id %>" method="POST" class="d-inline">
                    <button class="btn btn-sm <%= c.is_active ? 'btn-warning' : 'btn-success' %>">
                      <%= c.is_active ? 'Disable' : 'Enable' %>
                    </button>
                  </form>
                  <form action="/admin/coupons/delete/<%= c.id %>?_method=DELETE" method="POST" class="d-inline"
                    onsubmit="return confirm('Delete?')">
                    <button class="btn btn-sm btn-danger">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Add Coupon Modal -->
<div class="modal fade" id="addCouponModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form action="/admin/coupons/add" method="POST">
        <div class="modal-header bg-dark text-white">
          <h5 class="modal-title fw-bold">New Coupon</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="fw-bold">Coupon Code *</label>
            <input type="text" name="code" class="form-control text-uppercase" required placeholder="e.g. SAVE20">
          </div>
          <div class="row g-2 mb-3">
            <div class="col-6">
              <label class="fw-bold">Type *</label>
              <select name="type" class="form-select" required>
                <option value="percent">Percent (%)</option>
                <option value="fixed">Fixed Amount (₹)</option>
              </select>
            </div>
            <div class="col-6">
              <label class="fw-bold">Value *</label>
              <input type="number" name="value" class="form-control" required min="1" placeholder="e.g. 20">
            </div>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-6">
              <label class="fw-bold">Min Order (₹)</label>
              <input type="number" name="min_order" class="form-control" value="0" min="0">
            </div>
            <div class="col-6">
              <label class="fw-bold">Max Uses (blank = unlimited)</label>
              <input type="number" name="max_uses" class="form-control" min="1" placeholder="Unlimited">
            </div>
          </div>
          <div class="mb-3">
            <label class="fw-bold">Expiry Date (blank = no expiry)</label>
            <input type="date" name="expires_at" class="form-control">
          </div>
          <div class="d-flex gap-4">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" name="once_per_user" id="once_per_user" checked>
              <label class="form-check-label" for="once_per_user">Once Per User</label>
            </div>
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" name="is_active" id="is_active" checked>
              <label class="form-check-label" for="is_active">Active</label>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-warning fw-bold">Create Coupon</button>
        </div>
      </form>
    </div>
  </div>
</div>
    </div>
  </div>
</div>
<%- include("../partials/footer") %>
