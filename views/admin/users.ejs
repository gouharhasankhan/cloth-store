<%- include('./sidebar') %>
    <div class="col-md-10">
      <h3 class="fw-bold mb-4">Users</h3>
      <div class="table-responsive card shadow-sm">
        <table class="table table-hover mb-0">
          <thead class="table-dark">
            <tr><th>ID</th><th>Name</th><th>Email</th><th>Phone</th><th>Role</th><th>Joined</th></tr>
          </thead>
          <tbody>
            <% users.forEach(u => { %>
              <tr>
                <td><%= u.id %></td>
                <td><%= u.name %></td>
                <td><%= u.email %></td>
                <td><%= u.phone || '-' %></td>
                <td><span class="badge bg-<%= u.role === 'admin' ? 'danger' : 'primary' %>"><%= u.role %></span></td>
                <td><%= new Date(u.created_at).toLocaleDateString('hi-IN') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
 

