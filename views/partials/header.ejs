<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | <%= appName %></title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <!-- Custom Advanced Styles for Header -->
  <style>
    .navbar-logo{
    height: 70px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
}

/* Tablet */
@media (max-width: 992px){
    .navbar-logo{
        height: 55px;
    }
}

/* Mobile */
@media (max-width: 576px){
    .navbar-logo{
        height: 50px;
    }
}
    /* Premium Navbar Styles */
    .navbar {
      backdrop-filter: blur(12px);
      background: rgba(33, 37, 41, 0.85) !important;
      transition: all 0.4s ease;
      border-bottom: 1px solid rgba(255, 193, 7, 0.2);
    }
    
    .navbar.scrolled {
      background: rgba(0, 0, 0, 0.95) !important;
      box-shadow: 0 10px 30px -10px rgba(0,0,0,0.5);
    }
    
    .navbar-brand {
      position: relative;
      overflow: hidden;
      transition: transform 0.3s ease;
    }
    
    .navbar-brand:hover {
      transform: scale(1.02);
    }
    
    .navbar-brand i {
      transition: transform 0.3s ease;
    }
    
    .navbar-brand:hover i {
      transform: rotate(-5deg);
    }
    
    /* Animated Underline for Nav Links */
    .navbar-nav .nav-link {
      position: relative;
      font-weight: 500;
      margin: 0 4px;
      transition: color 0.3s ease;
    }
    
    .navbar-nav .nav-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      width: 0;
      height: 2px;
      background: linear-gradient(90deg, #ffd700, #ff9f00);
      transition: all 0.3s ease;
      transform: translateX(-50%);
      border-radius: 2px;
    }
    
    .navbar-nav .nav-link:hover::after,
    .navbar-nav .nav-link.active::after {
      width: 80%;
    }
    
    /* Dropdown Menu Premium */
    .dropdown-menu {
      background: rgba(33, 37, 41, 0.95);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,193,7,0.3);
      border-radius: 16px;
      box-shadow: 0 15px 35px rgba(0,0,0,0.3);
      padding: 0.5rem 0;
      margin-top: 8px;
      animation: fadeInUp 0.2s ease;
    }
    
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    .dropdown-item {
      color: #f8f9fa;
      padding: 8px 20px;
      transition: all 0.2s ease;
      font-weight: 500;
    }
    
    .dropdown-item i {
      width: 20px;
      margin-right: 8px;
      transition: transform 0.2s ease;
    }
    
    .dropdown-item:hover {
      background: linear-gradient(90deg, rgba(255,193,7,0.2), transparent);
      color: #ffd700;
      transform: translateX(5px);
    }
    
    .dropdown-item:hover i {
      transform: translateX(3px);
      color: #ffd700;
    }
    
    .dropdown-divider {
      border-top: 1px solid rgba(255,255,255,0.1);
    }
    
    /* Search Bar Enhancement */
    .search-wrapper {
      position: relative;
    }
    
    .search-input {
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 50px;
      padding: 8px 18px;
      color: white;
      transition: all 0.3s ease;
      width: 220px;
    }
    
    .search-input:focus {
      background: rgba(255,255,255,0.2);
      border-color: #ffd700;
      box-shadow: 0 0 0 3px rgba(255,193,7,0.3);
      outline: none;
      width: 280px;
    }
    
    .search-input::placeholder {
      color: rgba(255,255,255,0.6);
    }
    
    .search-btn {
      border-radius: 50px;
      background: linear-gradient(135deg, #ffd700, #ff9f00);
      border: none;
      width: 42px;
      transition: all 0.3s ease;
    }
    
    .search-btn:hover {
      transform: scale(1.05);
      box-shadow: 0 0 12px rgba(255,193,7,0.5);
    }
    
    /* Cart Icon with Badge */
    .cart-link {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    
    .cart-badge {
      position: absolute;
      top: -8px;
      right: -12px;
      background: linear-gradient(135deg, #ff4444, #cc0000);
      border-radius: 50px;
      padding: 2px 6px;
      font-size: 0.7rem;
      font-weight: bold;
      min-width: 18px;
      text-align: center;
      box-shadow: 0 0 6px rgba(255,68,68,0.5);
    }
    
    /* Login/Register Buttons */
    .btn-outline-warning-custom {
      background: transparent;
      border: 1px solid #ffd700;
      color: #ffd700;
      border-radius: 30px;
      padding: 5px 18px;
      transition: all 0.3s ease;
    }
    
    .btn-outline-warning-custom:hover {
      background: #ffd700;
      color: #1a1a2e;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(255,193,7,0.3);
    }
    
    .btn-warning-custom {
      background: linear-gradient(135deg, #ffd700, #ff9f00);
      border: none;
      border-radius: 30px;
      padding: 5px 20px;
      color: #1a1a2e;
      font-weight: 600;
      transition: all 0.3s ease;
    }
    
    .btn-warning-custom:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(255,193,7,0.4);
    }
    
    /* Flash Messages Premium */
    .alert {
      border-radius: 16px;
      border: none;
      backdrop-filter: blur(10px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.1);
      animation: slideDown 0.4s ease;
    }
    
    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    .alert-success {
      background: linear-gradient(135deg, rgba(40,167,69,0.9), rgba(40,167,69,0.7));
      color: white;
    }
    
    .alert-danger {
      background: linear-gradient(135deg, rgba(220,53,69,0.9), rgba(220,53,69,0.7));
      color: white;
    }
    
    /* Responsive Tweaks */
    @media (max-width: 992px) {
      .search-input {
        width: 100%;
        margin-bottom: 8px;
      }
      .search-input:focus {
        width: 100%;
      }
      .navbar-nav .nav-link::after {
        bottom: -4px;
      }
    }
    
    /* Mobile Menu Animation */
    .navbar-collapse {
      transition: all 0.3s ease;
    }
    
    /* User Avatar Style */
    .user-avatar {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      background: linear-gradient(135deg, #ffd700, #ff9f00);
      border-radius: 50%;
      margin-right: 8px;
      color: #1a1a2e;
      font-weight: bold;
    }


/* =========================
   ULTRA PREMIUM NAVBAR
========================= */

.premium-navbar{

  background:
    rgba(5,10,20,.72)!important;

  backdrop-filter:blur(20px);

  border-bottom:
    1px solid rgba(255,255,255,.08);

  padding:14px 0;

  transition:.4s ease;

  box-shadow:
    0 10px 35px rgba(0,0,0,.22);
}

/* SCROLL EFFECT */

.premium-navbar.scrolled{

  background:
    rgba(2,6,23,.92)!important;

  backdrop-filter:blur(24px);

  padding:10px 0;

  box-shadow:
    0 20px 40px rgba(0,0,0,.35);
}

/* BRAND */

.navbar-brand{

  font-size:2rem!important;

  font-weight:900!important;

  letter-spacing:-1px;

  color:white!important;

  display:flex;
  align-items:center;
  gap:10px;
}

.navbar-brand i{

  color:#facc15;

  font-size:1.8rem;

  transform:rotate(-8deg);
}

/* NAV LINKS */

.navbar-nav{

  gap:10px;
}

.nav-link{

  position:relative;

  color:#e2e8f0!important;

  font-weight:600;

  padding:10px 16px!important;

  border-radius:14px;

  transition:.35s;
}

.nav-link:hover{

  background:
    rgba(255,255,255,.06);

  color:#fff!important;
}

.nav-link::after{

  content:'';

  position:absolute;

  left:50%;
  bottom:4px;

  width:0;
  height:2px;

  transform:
    translateX(-50%);

  background:
    linear-gradient(
      90deg,
      #facc15,
      #f59e0b
    );

  border-radius:20px;

  transition:.35s;
}

.nav-link:hover::after{
  width:60%;
}

/* SEARCH BAR */

.search-wrapper{

  position:relative;
}

.search-input{

  width:240px!important;

  background:
    rgba(255,255,255,.06)!important;

  border:
    1px solid rgba(255,255,255,.08)!important;

  border-radius:18px!important;

  padding:
    12px 18px!important;

  color:white!important;

  transition:.4s;
}

.search-input:focus{

  width:300px!important;

  background:
    rgba(255,255,255,.1)!important;

  border-color:
    #facc15!important;

  box-shadow:
    0 0 0 4px rgba(250,204,21,.15)!important;
}

.search-input::placeholder{
  color:#94a3b8!important;
}

/* SEARCH BUTTON */

.search-btn{

  width:48px;
  height:48px;

  border-radius:16px!important;

  background:
    linear-gradient(
      135deg,
      #facc15,
      #f59e0b
    )!important;

  border:none!important;

  transition:.35s;
}

.search-btn:hover{

  transform:
    translateY(-3px)
    scale(1.04);

  box-shadow:
    0 10px 25px rgba(250,204,21,.35);
}

/* LOGIN BUTTON */

.btn-outline-warning-custom{

  border:none!important;

  background:
    rgba(255,255,255,.06);

  color:white!important;

  border-radius:16px!important;

  padding:
    10px 18px!important;

  transition:.35s;
}

.btn-outline-warning-custom:hover{

  background:
    rgba(255,255,255,.12);

  transform:
    translateY(-3px);
}

/* REGISTER BUTTON */

.btn-warning-custom{

  border:none!important;

  background:
    linear-gradient(
      135deg,
      #facc15,
      #f59e0b
    )!important;

  color:#111827!important;

  border-radius:16px!important;

  padding:
    10px 20px!important;

  font-weight:700!important;

  transition:.35s;
}

.btn-warning-custom:hover{

  transform:
    translateY(-3px);

  box-shadow:
    0 10px 25px rgba(250,204,21,.35);
}

/* USER AVATAR */

.user-avatar{

  width:38px!important;
  height:38px!important;

  border-radius:14px!important;

  background:
    linear-gradient(
      135deg,
      #facc15,
      #f59e0b
    )!important;

  color:#111827!important;

  font-weight:800!important;
}

/* DROPDOWN */

.dropdown-menu{

  background:
    rgba(15,23,42,.92)!important;

  backdrop-filter:blur(20px);

  border:
    1px solid rgba(255,255,255,.08)!important;

  border-radius:22px!important;

  padding:12px!important;

  min-width:240px;

  box-shadow:
    0 25px 50px rgba(0,0,0,.4);
}

.dropdown-item{

  border-radius:14px!important;

  padding:
    12px 16px!important;

  color:#e2e8f0!important;

  transition:.3s;
}

.dropdown-item:hover{

  background:
    rgba(255,255,255,.06)!important;

  color:#facc15!important;

  transform:
    translateX(5px);
}

/* CART */

.cart-link{

  background:
    rgba(255,255,255,.05);

  padding:
    10px 16px;

  border-radius:16px;

  transition:.35s;
}

.cart-link:hover{

  background:
    rgba(255,255,255,.1);

  transform:
    translateY(-3px);
}

/* MOBILE */

@media(max-width:991px){

  .navbar-collapse{

    margin-top:18px;

    padding:20px;

    border-radius:24px;

    background:
      rgba(15,23,42,.95);

    backdrop-filter:blur(20px);

    border:
      1px solid rgba(255,255,255,.08);
  }

  .navbar-nav{

    gap:6px;
  }

  .search-wrapper{

    width:100%;
    margin:
      20px 0!important;
  }

  .search-input{

    width:100%!important;
  }

  .search-input:focus{

    width:100%!important;
  }

  .search-btn{

    width:100%;
    margin-top:12px;
  }

}

/* TOGGLER */

.navbar-toggler{

  border:none!important;

  box-shadow:none!important;

  background:
    rgba(255,255,255,.06);

  border-radius:14px;

  padding:10px 14px;
}

  </style>
</head>
<body>

<!-- NAVBAR with Glassmorphism -->
<nav class="navbar navbar-expand-lg navbar-dark sticky-top premium-navbar">
  <div class="container">
  <a class="navbar-brand d-flex align-items-center" href="/">
    <img src="/images/logo.png" alt="GHK Fashion Hub" class="navbar-logo">
</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    
    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" aria-expanded="false">
            Categories
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/products?category=men"><i class="fas fa-male"></i> Men</a></li>
            <li><a class="dropdown-item" href="/products?category=women"><i class="fas fa-female"></i> Women</a></li>
            <li><a class="dropdown-item" href="/products?category=kids"><i class="fas fa-child"></i> Kids</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="/products?category=ethnic-wear"><i class="fas fa-star"></i> Ethnic Wear</a></li>
            <li><a class="dropdown-item" href="/products?category=western-wear"><i class="fas fa-tshirt"></i> Western Wear</a></li>
          </ul>
        </li>
      </ul>
      
      <!-- Advanced Search Form -->
      <form class="d-flex me-3 search-wrapper" action="/products" method="GET">
        <input class="form-control search-input" type="search" name="search" placeholder="Search clothes..." aria-label="Search">
        <button class="btn search-btn ms-2" type="submit">
          <i class="fas fa-search text-dark"></i>
        </button>
      </form>

      <ul class="navbar-nav align-items-center">
        <% if (user) { %>
          <li class="nav-item me-2">
            <a class="nav-link cart-link" href="/cart">
              <i class="fas fa-shopping-cart fa-lg"></i> Cart
              <!-- Optional: you can add a dynamic cart count if available -->
              <!-- <span class="cart-badge">3</span> -->
            </a>
          </li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" data-bs-toggle="dropdown" aria-expanded="false">
              <span class="user-avatar"><%= user.name.charAt(0).toUpperCase() %></span>
              <span><%= user.name.split(' ')[0] %></span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <% if (user.role === 'admin') { %>
                <li><a class="dropdown-item" href="/admin/dashboard"><i class="fas fa-tachometer-alt me-1"></i> Admin Panel</a></li>
                <li><hr class="dropdown-divider"></li>
              <% } %>
              <li><a class="dropdown-item" href="/auth/profile"><i class="fas fa-user-circle me-1"></i> My Profile</a></li>
              <li><a class="dropdown-item" href="/orders"><i class="fas fa-box me-1"></i> My Orders</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="fas fa-sign-out-alt me-1"></i> Logout</a></li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link btn-outline-warning-custom me-2" href="/auth/login">
              <i class="fas fa-sign-in-alt me-1"></i>Login
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link btn-warning-custom" href="/auth/register">
              <i class="fas fa-user-plus me-1"></i>Register
            </a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
<!-- ====== ANNOUNCEMENT BANNER ====== -->
<% if(typeof bannerEnabled !== 'undefined' && bannerEnabled && bannerText) { %>
  <div class="alert alert-<%= bannerColor %> text-center py-2 mb-0 rounded-0 fw-bold" style="font-size:0.95rem;">
    <i class="fas fa-bullhorn me-2"></i><%= bannerText %>
  </div>
<% } %>


<!-- Enhanced Flash Messages -->
<div class="container mt-3">
  <% if (success && success.length > 0) { %>
    <div class="alert alert-success alert-dismissible fade show shadow-lg" role="alert">
      <i class="fas fa-check-circle me-2"></i><%= success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="alert alert-danger alert-dismissible fade show shadow-lg" role="alert">
      <i class="fas fa-exclamation-circle me-2"></i><%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
</div>

<!-- Small Script for Navbar Scroll Effect -->
<script>
  // Add shadow on scroll
  window.addEventListener('scroll', function() {
const navbar = document.querySelector('.navbar');
    if (window.scrollY > 50) {
      navbar.classList.add('scrolled');
    } else {
      navbar.classList.remove('scrolled');
    }
  });
  
  // Auto-dismiss flash messages after 5 seconds
  setTimeout(function() {
    const alerts = document.querySelectorAll('.alert');
    alerts.forEach(alert => {
      const bsAlert = new bootstrap.Alert(alert);
      bsAlert.close();
    });
  }, 5000);
</script>

<!-- Keep original Bootstrap JS (needed for dropdowns, toggles) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>