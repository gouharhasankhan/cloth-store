
<%- include('../partials/header') %>
<style>
  /* FILTER CARD */

.card{
    border-radius:20px;
}

.card-header{
    border:none;
}

.list-group-item{
    border:none;
    border-radius:12px !important;
    margin-bottom:6px;
    transition:.3s;
}

.list-group-item:hover{
    background:#f8f9fa;
    transform:translateX(5px);
}

.list-group-item.active{
    background:#111 !important;
    border-color:#111 !important;
}

/* PRODUCT CARD */

.product-card{
    border-radius:20px;
    overflow:hidden;
    transition:.35s;
}

.product-card:hover{
    transform:translateY(-8px);
    box-shadow:0 15px 35px rgba(0,0,0,.15)!important;
}

.product-card img{
    transition:.5s;
}

.product-card:hover img{
    transform:scale(1.05);
}

/* OFFCANVAS */

.offcanvas{
    width:320px !important;
}

.offcanvas-header{
    background:#111;
    color:#fff;
}

.offcanvas-title{
    color:#fff;
}

/* MOBILE */

@media(max-width:768px){

    .container{
        padding-left:12px;
        padding-right:12px;
    }

    .product-card img{
        height:190px !important;
    }

    .btn-dark{
        border-radius:12px;
    }
}
</style>
<div class="container my-4">

  <div class="row g-4">

    <!-- FILTER SIDEBAR -->

  <div class="col-md-3 d-none d-md-block">

      <div class="card shadow-sm border-0">

        <!-- HEADER -->

        <div class="card-header bg-dark text-white fw-bold">

          <i class="fas fa-filter me-2"></i>

          Filters

        </div>

        <!-- BODY -->

        <div class="card-body">

          <form method="GET" action="/products">

            <!-- CATEGORY -->

            <h6 class="fw-bold mb-2">

              Category

            </h6>

            <div class="list-group list-group-flush mb-3">

              <!-- ALL PRODUCTS -->

              <a
                href="/products"
                class="list-group-item list-group-item-action <%= !filters.category ? 'active' : '' %>"
              >

                All Products

              </a>

              <!-- CATEGORIES -->

              <% categories.forEach(cat => { %>

                <a
                  href="/products?category=<%= cat.slug %>"
                  class="list-group-item list-group-item-action <%= filters.category === cat.slug ? 'active' : '' %>"
                >

                  <%= cat.name %>

                </a>

              <% }) %>

            </div>

            <!-- PRICE FILTER -->

            <h6 class="fw-bold mb-2">

              Price Range

            </h6>

            <div class="row g-2 mb-3">

              <!-- MIN -->

              <div class="col-6">

                <input
                  type="number"
                  name="minPrice"
                  class="form-control form-control-sm"
                  placeholder="Min ₹"
                  value="<%= filters.minPrice || '' %>"
                >

              </div>

              <!-- MAX -->

              <div class="col-6">

                <input
                  type="number"
                  name="maxPrice"
                  class="form-control form-control-sm"
                  placeholder="Max ₹"
                  value="<%= filters.maxPrice || '' %>"
                >

              </div>

            </div>

            <!-- SORT -->

            <h6 class="fw-bold mb-2">

              Sort By

            </h6>

            <select
              name="sort"
              class="form-select form-select-sm mb-3"
            >

              <option value="">

                Default

              </option>

              <option
                value="price_low"
                <%= filters.sort === 'price_low' ? 'selected' : '' %>
              >

                Price: Low to High

              </option>

              <option
                value="price_high"
                <%= filters.sort === 'price_high' ? 'selected' : '' %>
              >

                Price: High to Low

              </option>

              <option
                value="newest"
                <%= filters.sort === 'newest' ? 'selected' : '' %>
              >

                Newest First

              </option>

            </select>

            <!-- HIDDEN CATEGORY -->

            <% if (filters.category) { %>

              <input
                type="hidden"
                name="category"
                value="<%= filters.category %>"
              >

            <% } %>

            <!-- BUTTONS -->

            <button
              type="submit"
              class="btn btn-dark w-100"
            >

              Apply Filters

            </button>

            <a
              href="/products"
              class="btn btn-outline-secondary w-100 mt-2"
            >

              Reset Filters

            </a>

          </form>

        </div>

      </div>

    </div>

    <!-- PRODUCTS GRID -->

    <div class="col-md-9">

      <!-- TOP BAR -->
<div class="d-flex justify-content-between align-items-center mb-4">

    <h4 class="fw-bold mb-0">
        Products
        <span class="badge bg-dark ms-1">
            <%= products.length %>
        </span>
    </h4>

    <button class="btn btn-dark d-md-none"
            data-bs-toggle="offcanvas"
            data-bs-target="#filterDrawer">

        <i class="fas fa-sliders-h me-2"></i>
        Filters

    </button>

</div>

<% if (filters.search) { %>

<div class="alert alert-light border mb-4">
    Search Results for:
    <strong><%= filters.search %></strong>
</div>

<% } %>

        <!-- SEARCH -->

        <% if (filters.search) { %>

          <span class="text-muted">

            Search:
            "<%= filters.search %>"

          </span>

        <% } %>


      <!-- EMPTY -->

      <% if (products.length === 0) { %>

        <div class="text-center py-5">

          <i class="fas fa-search fa-4x text-muted mb-3"></i>

          <h4 class="text-muted">

            No products found

          </h4>

          <a
            href="/products"
            class="btn btn-dark mt-2"
          >

            View All Products

          </a>

        </div>

      <% } else { %>

        <!-- PRODUCTS -->

        <div class="row g-3">

          <% products.forEach(product => { %>

            <div class="col-6 col-lg-4">

              <div class="card border-0 shadow-sm h-100 product-card">

                <!-- IMAGE -->

                <div class="position-relative">

                  <img
                    src="<%= product.image || '/images/default.jpg' %>"
                    class="card-img-top"
                    alt="<%= product.name %>"
                    style="height:250px; object-fit:cover;"
                  >

                  <!-- DISCOUNT -->

                  <% if (product.discount_price) { %>

                    <span
                      class="badge bg-danger position-absolute top-0 start-0 m-2"
                    >

                      <%= Math.round(((product.price - product.discount_price) / product.price) * 100) %>% OFF

                    </span>

                  <% } %>

                  <!-- STOCK -->

                  <% if (product.stock === 0) { %>

                    <span
                      class="badge bg-secondary position-absolute top-0 end-0 m-2"
                    >

                      Out of Stock

                    </span>

                  <% } %>

                </div>

                <!-- BODY -->

                <div class="card-body">

                  <!-- CATEGORY -->

                  <span class="badge bg-light text-dark mb-1">

                    <%= product.category_name || 'Uncategorized' %>

                  </span>

                  <!-- NAME -->

                  <h6 class="card-title fw-bold text-truncate">

                    <%= product.name %>

                  </h6>

                  <!-- PRICE -->

                  <div class="d-flex align-items-center gap-2 mb-2">

                    <% if (product.discount_price) { %>

                      <span class="text-danger fw-bold fs-5">

                        ₹<%= product.discount_price %>

                      </span>

                      <small class="text-muted text-decoration-line-through">

                        ₹<%= product.price %>

                      </small>

                    <% } else { %>

                      <span class="fw-bold fs-5">

                        ₹<%= product.price %>

                      </span>

                    <% } %>

                  </div>

                  <!-- BUTTON -->

                  <a
                    href="/products/<%= product.id %>"
                    class="btn btn-dark btn-sm w-100"
                  >

                    <i class="fas fa-eye me-1"></i>

                    View Details

                  </a>

                </div>

              </div>

            </div>

          <% }) %>

        </div>

      <% } %>

    </div>

  </div>
<div class="offcanvas offcanvas-start" tabindex="-1" id="filterDrawer">

    <div class="offcanvas-header border-bottom">

        <h5 class="offcanvas-title fw-bold">
            <i class="fas fa-filter me-2"></i>
            Filters
        </h5>

        <button
            type="button"
            class="btn-close"
            data-bs-dismiss="offcanvas">
        </button>

    </div>

    <div class="offcanvas-body">

        <form method="GET" action="/products">

            <div class="mb-4">

                <label class="fw-bold mb-2">
                    Category
                </label>

                <select
                    name="category"
                    class="form-select">

                    <option value="">
                        All Products
                    </option>

                    <% categories.forEach(cat => { %>

                        <option
                            value="<%= cat.slug %>"
                            <%= filters.category === cat.slug ? 'selected' : '' %>>
                            <%= cat.name %>
                        </option>

                    <% }) %>

                </select>

            </div>

            <div class="mb-4">

                <label class="fw-bold mb-2">
                    Price Range
                </label>

                <input
                    type="number"
                    name="minPrice"
                    class="form-control mb-2"
                    placeholder="Min Price"
                    value="<%= filters.minPrice || '' %>">

                <input
                    type="number"
                    name="maxPrice"
                    class="form-control"
                    placeholder="Max Price"
                    value="<%= filters.maxPrice || '' %>">

            </div>

            <div class="mb-4">

                <label class="fw-bold mb-2">
                    Sort By
                </label>

                <select
                    name="sort"
                    class="form-select">

                    <option value="">
                        Default
                    </option>

                    <option
                        value="price_low"
                        <%= filters.sort === 'price_low' ? 'selected' : '' %>>
                        Price Low → High
                    </option>

                    <option
                        value="price_high"
                        <%= filters.sort === 'price_high' ? 'selected' : '' %>>
                        Price High → Low
                    </option>

                    <option
                        value="newest"
                        <%= filters.sort === 'newest' ? 'selected' : '' %>>
                        Newest First
                    </option>

                </select>

            </div>

            <button
                class="btn btn-dark w-100">

                Apply Filters

            </button>

            <a
                href="/products"
                class="btn btn-outline-secondary w-100 mt-2">

                Reset

            </a>

        </form>

    </div>

</div>
</div>

<%- include('../partials/footer') %>
