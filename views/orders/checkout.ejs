<%- include('../partials/header') %>

<div class="container my-4">

  <h2 class="fw-bold mb-4">
    <i class="fas fa-credit-card me-2"></i>
    Checkout
  </h2>

  <div class="row g-4">

    <!-- DELIVERY DETAILS -->
    <div class="col-md-7">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white fw-bold">
          Delivery Details
        </div>
        <div class="card-body">

          <!-- ADDRESS FIELD (shared for both COD & Razorpay) -->
          <div class="mb-3">
            <label class="fw-bold">Delivery Address *</label>
            <textarea
              id="shipping_address"
              name="shipping_address"
              class="form-control"
              rows="3"
              required
              placeholder="Enter your complete delivery address..."
            ><%= profile.address || '' %></textarea>
          </div>

          <!-- PAYMENT METHOD -->
          <div class="mb-3">
            <label class="fw-bold mb-2 d-block">Payment Method *</label>
            <div class="d-flex gap-3 flex-wrap">

              <!-- COD -->
              <div class="form-check">
                <input class="form-check-input" type="radio" name="payment_method" value="COD" id="cod" checked>
                <label class="form-check-label fw-bold" for="cod">
                  <i class="fas fa-money-bill-wave me-1 text-success"></i>
                  Cash on Delivery
                </label>
              </div>

              <!-- RAZORPAY -->
              <div class="form-check">
                <input class="form-check-input" type="radio" name="payment_method" value="Razorpay" id="razorpay">
                <label class="form-check-label fw-bold" for="razorpay">
                  <i class="fas fa-bolt me-1 text-primary"></i>
                  UPI / Card / Net Banking
                </label>
              </div>

            </div>
          </div>

          <!-- INFO ALERT -->
          <div class="alert alert-info" id="cod-info">
            <i class="fas fa-info-circle me-2"></i>
            Cash on Delivery: Payment delivery pe hogi.
          </div>
          <div class="alert alert-primary d-none" id="razorpay-info">
            <i class="fas fa-shield-alt me-2"></i>
            UPI, Debit/Credit Card, Net Banking — Razorpay secure payment.
          </div>

          <!-- COD FORM -->
          <form id="cod-form" action="/orders/place" method="POST">
            <input type="hidden" name="payment_method" value="COD">
            <input type="hidden" name="shipping_address" id="cod-address">
            <button type="submit" id="cod-btn" class="btn btn-warning w-100 py-3 fw-bold fs-5">
              <i class="fas fa-check-circle me-2"></i>
              Place Order (COD)
            </button>
          </form>

          <!-- RAZORPAY BUTTON -->
          <button
            id="razorpay-btn"
            class="btn btn-primary w-100 py-3 fw-bold fs-5 d-none"
            onclick="startRazorpayPayment()"
          >
            <i class="fas fa-bolt me-2"></i>
            Pay Now with Razorpay
          </button>

        </div>
      </div>
    </div>

    <!-- ORDER SUMMARY -->
    <div class="col-md-5">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white fw-bold">
          Order Summary
        </div>
        <div class="card-body">

          <% items.forEach(item => { %>
            <div class="d-flex justify-content-between mb-2 align-items-center">
              <div class="d-flex align-items-center gap-2">
                <img
                  src="<%= item.image || '/images/default.jpg' %>"
                  style="width:40px;height:40px;object-fit:cover;"
                  class="rounded"
                >
                <div>
                  <small class="fw-bold d-block" style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                    <%= item.name %>
                  </small>
                  <small class="text-muted">x<%= item.quantity %></small>
                </div>
              </div>
              <span>₹<%= ((item.discount_price || item.price) * item.quantity).toFixed(2) %></span>
            </div>
          <% }) %>

          <hr>

          <div class="d-flex justify-content-between">
            <span>Delivery</span>
            <span class="text-success"><%= total >= 500 ? 'Free' : '₹50' %></span>
          </div>

          <div class="d-flex justify-content-between fw-bold fs-5 mt-2">
            <span>Total</span>
            <span class="text-danger">₹<%= (total + (total >= 500 ? 0 : 50)).toFixed(2) %></span>
          </div>

        </div>
      </div>
    </div>

  </div>
</div>

<!-- Razorpay SDK -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
  const RAZORPAY_KEY_ID = '<%= razorpayKeyId %>';
  const TOTAL_AMOUNT = <%= (total + (total >= 500 ? 0 : 50)).toFixed(2) %>;

  // Payment method toggle
  document.querySelectorAll('input[name="payment_method"]').forEach(radio => {
    radio.addEventListener('change', function() {
      const isCOD = this.value === 'COD';
      document.getElementById('cod-form').classList.toggle('d-none', !isCOD);
      document.getElementById('razorpay-btn').classList.toggle('d-none', isCOD);
      document.getElementById('cod-info').classList.toggle('d-none', !isCOD);
      document.getElementById('razorpay-info').classList.toggle('d-none', isCOD);
    });
  });

  // COD form pe address copy karein
  document.getElementById('cod-form').addEventListener('submit', function(e) {
    const addr = document.getElementById('shipping_address').value.trim();
    if (!addr) {
      e.preventDefault();
      alert('Delivery address enter karein!');
      document.getElementById('shipping_address').focus();
      return;
    }
    document.getElementById('cod-address').value = addr;
  });

  // Razorpay payment
  async function startRazorpayPayment() {
    const address = document.getElementById('shipping_address').value.trim();
    if (!address) {
      alert('Delivery address enter karein!');
      document.getElementById('shipping_address').focus();
      return;
    }

    const btn = document.getElementById('razorpay-btn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Processing...';

    try {
      // Backend se Razorpay order banao
      const response = await fetch('/orders/razorpay/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ shipping_address: address })
      });

      const data = await response.json();

      if (!data.success) {
        alert(data.message || 'Error aaya, dobara try karein');
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-bolt me-2"></i> Pay Now with Razorpay';
        return;
      }

      // Razorpay checkout open karein
      const options = {
        key: RAZORPAY_KEY_ID,
        amount: data.amount,
        currency: data.currency,
        name: 'FashionHub',
        description: 'Order Payment',
        order_id: data.razorpay_order_id,
        prefill: {
          name: data.user.name || '',
          email: data.user.email || '',
          contact: data.user.phone || ''
        },
        theme: { color: '#212529' },
        handler: function(paymentResponse) {
          // Payment successful - verify karein
          const form = document.createElement('form');
          form.method = 'POST';
          form.action = '/orders/razorpay/verify';

          const fields = {
            razorpay_order_id: paymentResponse.razorpay_order_id,
            razorpay_payment_id: paymentResponse.razorpay_payment_id,
            razorpay_signature: paymentResponse.razorpay_signature,
            order_db_id: data.order_db_id,
            shipping_address: address
          };

          for (const [key, val] of Object.entries(fields)) {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = key;
            input.value = val;
            form.appendChild(input);
          }

          document.body.appendChild(form);
          form.submit();
        },
        modal: {
          ondismiss: function() {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-bolt me-2"></i> Pay Now with Razorpay';
          }
        }
      };

      const rzp = new Razorpay(options);
      rzp.on('payment.failed', function(response) {
        alert('Payment fail ho gayi: ' + response.error.description);
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-bolt me-2"></i> Pay Now with Razorpay';
      });
      rzp.open();

    } catch (err) {
      console.error(err);
      alert('Network error, dobara try karein');
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-bolt me-2"></i> Pay Now with Razorpay';
    }
  }
</script>

<%- include('../partials/footer') %>
