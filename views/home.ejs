<%- include('partials/header') %>

<!-- Custom Styles for Advanced Design -->
<style>
  /* Import Modern Fonts */
  @import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap');
  
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
  }

  /* Floating Shapes Animation */
  .floating-shape {
    position: absolute;
    z-index: 0;
    opacity: 0.1;
    pointer-events: none;
    animation: float 20s infinite ease-in-out;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-30px) rotate(10deg); }
  }

  /* Hero Section Enhancement */
  .hero-section {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #0a0a1a 0%, #1a1a3e 50%, #0f3460 100%);
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 20% 50%, rgba(255,193,7,0.15) 0%, transparent 50%);
    animation: pulseGlow 4s ease-in-out infinite;
  }

  @keyframes pulseGlow {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  .hero-title span {
    background: linear-gradient(135deg, #ffd700, #ff9f00);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shimmer 3s infinite;
  }

  @keyframes shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .btn-warning {
    background: linear-gradient(135deg, #ffd700, #ff9f00);
    border: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(255,159,0,0.3);
  }

  .btn-warning:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(255,159,0,0.5);
  }

  .btn-outline-light:hover {
    transform: translateY(-3px);
    background: rgba(255,255,255,0.1);
  }

  /* Category Cards Glassmorphism */
  .category-card {
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(10px);
    border-radius: 20px !important;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    overflow: hidden;
  }

  .category-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 20px 30px -12px rgba(0,0,0,0.2);
  }

  .category-card i {
    transition: all 0.3s ease;
  }

  .category-card:hover i {
    transform: scale(1.1);
    text-shadow: 0 0 15px rgba(255,193,7,0.5);
  }

  /* Product Cards Premium Design */
  .product-card {
    border-radius: 16px !important;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
  }

  .product-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #ffd700, #ff9f00);
    transform: scaleX(0);
    transition: transform 0.3s ease;
    z-index: 1;
  }

  .product-card:hover::before {
    transform: scaleX(1);
  }

  .product-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 25px 35px -15px rgba(0,0,0,0.3);
  }

  .product-card img {
    transition: transform 0.5s ease;
  }

  .product-card:hover img {
    transform: scale(1.05);
  }

  .product-card .btn-dark {
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    border: none;
    transition: all 0.3s ease;
  }

  .product-card .btn-dark:hover {
    background: linear-gradient(135deg, #ffd700, #ff9f00);
    color: #1a1a2e;
    transform: translateY(-2px);
  }

  /* New Arrivals Section Premium */
  .bg-dark-glass {
    background: linear-gradient(135deg, #0f0f1f, #1a1a2e);
    position: relative;
    overflow: hidden;
  }

  .bg-dark-glass::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255,193,7,0.05) 0%, transparent 70%);
    animation: rotateBg 20s linear infinite;
  }

  @keyframes rotateBg {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Feature Icons Animation */
  .feature-icon {
    transition: all 0.3s ease;
    display: inline-block;
  }

  .feature-item:hover .feature-icon {
    transform: translateY(-8px) scale(1.1);
    text-shadow: 0 0 20px rgba(255,193,7,0.6);
  }

  /* Button Ripple Effect */
  .btn {
    position: relative;
    overflow: hidden;
  }

  .btn::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    transform: translate(-50%, -50%);
    transition: width 0.4s ease, height 0.4s ease;
  }

  .btn:active::after {
    width: 100%;
    height: 100%;
  }

  /* Loading Animation for Cards */
  .card {
    animation: fadeInUp 0.6s ease backwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Stagger Animation for Product Cards */
  .product-card {
    animation: fadeInUp 0.6s ease backwards;
  }

  .product-card:nth-child(1) { animation-delay: 0.05s; }
  .product-card:nth-child(2) { animation-delay: 0.1s; }
  .product-card:nth-child(3) { animation-delay: 0.15s; }
  .product-card:nth-child(4) { animation-delay: 0.2s; }
  .product-card:nth-child(5) { animation-delay: 0.25s; }
  .product-card:nth-child(6) { animation-delay: 0.3s; }

  /* Custom Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: #1a1a2e;
  }

  ::-webkit-scrollbar-thumb {
    background: linear-gradient(135deg, #ffd700, #ff9f00);
    border-radius: 10px;
  }

  /* Responsive Typography Enhancements */
  @media (max-width: 768px) {
    .display-3 {
      font-size: 2.5rem;
    }
    .hero-section {
      min-height: 400px;
    }
  }

  /* Glass Card Effect for Categories on Mobile */
  @media (max-width: 576px) {
    .category-card {
      backdrop-filter: blur(5px);
    }
  }

  /* Smooth Hover for Section Headers */
  .section-header h2 {
    position: relative;
    display: inline-block;
  }

  .section-header h2::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, #ffd700, #ff9f00);
    border-radius: 3px;
    transition: width 0.3s ease;
  }

  .section-header:hover h2::after {
    width: 100px;
  }

  /* Badge Enhancement */
  .badge.bg-danger {
    background: linear-gradient(135deg, #ff4444, #cc0000) !important;
    padding: 5px 10px;
    font-weight: 600;
    letter-spacing: 0.5px;
    box-shadow: 0 2px 8px rgba(255,68,68,0.3);
  }

  /* Image Hover Zoom Container */
  .position-relative {
    overflow: hidden;
  }
</style>

<!-- HERO SECTION with Animated Background -->
<section class="hero-section text-white text-center py-5" style="min-height: 600px; display:flex; align-items:center; position: relative;">
  <!-- Floating Shapes for Visual Interest -->
  <div class="floating-shape" style="top: 10%; left: 5%; width: 150px; height: 150px; background: radial-gradient(circle, rgba(255,215,0,0.2), transparent); border-radius: 50%;"></div>
  <div class="floating-shape" style="bottom: 15%; right: 8%; width: 200px; height: 200px; background: radial-gradient(circle, rgba(255,159,0,0.15), transparent); border-radius: 50%; animation-delay: -5s;"></div>
  <div class="floating-shape" style="top: 50%; left: 20%; width: 100px; height: 100px; background: radial-gradient(circle, rgba(255,215,0,0.1), transparent); border-radius: 50%; animation-delay: -10s;"></div>
  
  <div class="container position-relative" style="z-index: 2;">
    <h1 class="display-3 fw-bold mb-3 hero-title">
      <span class="text-warning">Fashion</span>'s New Vibe
    </h1>
    <p class="lead mb-4 fs-4" style="font-weight: 400; letter-spacing: 0.5px;">Choose your style from India's best fashion collection</p>
    <div class="d-flex gap-3 justify-content-center flex-wrap">
      <a href="/products" class="btn btn-warning btn-lg px-5 py-3 fw-bold">
        <i class="fas fa-shopping-bag me-2"></i>Shop Now
      </a>
      <a href="/products?category=ethnic-wear" class="btn btn-outline-light btn-lg px-5 py-3">
        <i class="fas fa-star me-2"></i>Ethnic Wear
      </a>
    </div>
  </div>
</section>

<!-- CATEGORIES SECTION with Glassmorphism -->
<section class="py-5 bg-light position-relative">
  <div class="container">
    <div class="text-center mb-5 section-header">
      <h2 class="fw-bold display-6">Shop by <span class="text-warning">Categories</span></h2>
      <p class="text-muted mt-2">Explore the best collections curated just for you</p>
    </div>
    <div class="row g-4 justify-content-center">
      <% const catIcons = {men:'fa-male', women:'fa-female', kids:'fa-child', 'ethnic-wear':'fa-star', 'western-wear':'fa-tshirt'}; %>
      <% categories.forEach(cat => { %>
        <div class="col-6 col-md-2">
          <a href="/products?category=<%= cat.slug %>" class="text-decoration-none">
            <div class="card text-center border-0 shadow-sm h-100 category-card">
              <div class="card-body py-4">
                <i class="fas <%= catIcons[cat.slug] || 'fa-tag' %> fa-3x text-warning mb-3" style="transition: all 0.3s;"></i>
                <h6 class="fw-bold text-dark fs-6 mb-0"><%= cat.name %></h6>
                <small class="text-muted mt-1 d-block">Explore →</small>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- FEATURED PRODUCTS -->
<section class="py-5">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap section-header">
      <div>
        <h2 class="fw-bold display-6 mb-0">Featured <span class="text-warning">Products</span></h2>
        <p class="text-muted mt-2">Handpicked just for you</p>
      </div>
      <a href="/products" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-bold">View All <i class="fas fa-arrow-right ms-1"></i></a>
    </div>
    <div class="row g-4">
      <% featured.forEach(product => { %>
        <div class="col-6 col-md-4 col-lg-2">
          <div class="card border-0 shadow-sm h-100 product-card">
            <div class="position-relative">
              <img src="<%= product.image || '/images/default.jpg' %>" class="card-img-top" alt="<%= product.name %>" style="height:240px; object-fit:cover;">
              <% if (product.discount_price) { %>
                <span class="badge bg-danger position-absolute top-0 end-0 m-2 px-3 py-2 rounded-pill">SALE</span>
              <% } %>
              <div class="position-absolute bottom-0 start-0 end-0 bg-dark bg-opacity-75 text-white p-1 text-center small opacity-0 transition" style="transition: opacity 0.3s;">Quick View</div>
            </div>
            <div class="card-body">
              <h6 class="card-title fw-bold text-truncate"><%= product.name %></h6>
              <div class="d-flex align-items-center gap-2 mb-2">
                <% if (product.discount_price) { %>
                  <span class="text-danger fw-bold fs-5">₹<%= product.discount_price %></span>
                  <small class="text-muted text-decoration-line-through">₹<%= product.price %></small>
                <% } else { %>
                  <span class="fw-bold fs-5">₹<%= product.price %></span>
                <% } %>
              </div>
              <a href="/products/<%= product.id %>" class="btn btn-dark btn-sm w-100 rounded-pill py-2">
                <i class="fas fa-eye me-1"></i>View
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- NEW ARRIVALS with Premium Dark Glass Effect -->
<section class="py-5 bg-dark-glass text-white position-relative">
  <div class="container position-relative" style="z-index: 2;">
    <div class="text-center mb-5 section-header">
      <h2 class="fw-bold display-6">New <span class="text-warning">Arrivals</span></h2>
      <p class="text-light opacity-75 mt-2">Fresh styles to elevate your wardrobe</p>
    </div>
    <div class="row g-4">
      <% newArrivals.forEach(product => { %>
        <div class="col-6 col-md-3">
          <div class="card bg-secondary border-0 h-100 product-card" style="background: rgba(255,255,255,0.05) !important; backdrop-filter: blur(10px);">
            <div class="position-relative overflow-hidden">
              <img src="<%= product.image || '/images/default.jpg' %>" class="card-img-top" alt="<%= product.name %>" style="height:220px; object-fit:cover; transition: transform 0.5s;">
              <div class="position-absolute top-0 start-0 m-2">
                <span class="badge bg-warning text-dark rounded-pill px-3 py-1">New</span>
              </div>
            </div>
            <div class="card-body">
              <h6 class="text-truncate fw-bold text-white"><%= product.name %></h6>
              <p class="text-warning fw-bold fs-5 mb-2">₹<%= product.discount_price || product.price %></p>
              <a href="/products/<%= product.id %>" class="btn btn-warning btn-sm w-100 rounded-pill py-2 fw-semibold">Add to Cart <i class="fas fa-arrow-right ms-1"></i></a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- FEATURES SECTION with Enhanced Animations -->
<section class="py-5 bg-light">
  <div class="container">
    <div class="row g-5 text-center">
      <div class="col-md-3 feature-item">
        <div class="feature-icon">
          <i class="fas fa-shipping-fast fa-3x text-warning mb-3"></i>
        </div>
        <h5 class="fw-bold">Free Delivery</h5>
        <p class="text-muted mb-0">Free delivery on orders above ₹500</p>
      </div>
      <div class="col-md-3 feature-item">
        <div class="feature-icon">
          <i class="fas fa-undo fa-3x text-warning mb-3"></i>
        </div>
        <h5 class="fw-bold">Easy Returns</h5>
        <p class="text-muted mb-0">Return or exchange within 7 days</p>
      </div>
      <div class="col-md-3 feature-item">
        <div class="feature-icon">
          <i class="fas fa-shield-alt fa-3x text-warning mb-3"></i>
        </div>
        <h5 class="fw-bold">Secure Payment</h5>
        <p class="text-muted mb-0">100% secure payment gateway</p>
      </div>
      <div class="col-md-3 feature-item">
        <div class="feature-icon">
          <i class="fas fa-headset fa-3x text-warning mb-3"></i>
        </div>
        <h5 class="fw-bold">24/7 Support</h5>
        <p class="text-muted mb-0">Talk to us for any problem</p>
      </div>
    </div>
  </div>
</section>

<!-- Smooth Scroll Script (Optional Enhancement) -->
<script>
  // Smooth scroll for anchor links without breaking existing functionality
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Add hover quick view text effect for product cards
  document.querySelectorAll('.product-card .position-relative').forEach(card => {
    const overlay = card.querySelector('.position-absolute.bottom-0');
    if (overlay) {
      card.addEventListener('mouseenter', () => {
        overlay.style.opacity = '1';
      });
      card.addEventListener('mouseleave', () => {
        overlay.style.opacity = '0';
      });
    }
  });
</script>

<%- include('partials/footer') %>